# Server Environment Variables

# MongoDB Connection (Update with your MongoDB Atlas connection string)
MONGO_URI=mongodb+srv://rajatmalik:rajat123@cluster0.ybzr2.mongodb.net/tutor

# JWT Secret - Generate a strong random string for production
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server Port
PORT=5001

# Email Configuration (for OTP and notifications)
# For Gmail: use App Password (get from Google Account > Security > 2-Step > App Passwords)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_SERVICE=gmail

# Frontend URL - For CORS and email links
FRONTEND_URL=http://localhost:5173

